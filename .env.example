# BusTrack India — Environment Variables
# =========================================
# Copy this file to .env.local for local development with Vercel CLI.
# On production Vercel, set these in:
#   Dashboard → Your Project → Settings → Environment Variables
#
# NEVER commit real values to git. This .env.example is safe to commit.

# Your Supabase project URL
# Found at: supabase.com → Your Project → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon (public) key — safe to use in browser contexts
# Found at: supabase.com → Your Project → Settings → API → Project API Keys → anon public
# Use the ANON key, NOT the service_role key.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key-here
